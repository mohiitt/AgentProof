# Mohit / Codex / HydraDB
HYDRA_DB_ENABLED=false
HYDRA_DB_API_KEY=
HYDRA_DB_DATABASE_ID=
HYDRA_DB_BASE_URL=https://api.hydradb.com

# Teammate / Claude Code / RocketRide
# ROCKETRIDE_URI and ROCKETRIDE_APIKEY are normally auto-synced into .env (not
# .env.example) by the VS Code extension's "Connect to Server" command -- do
# not hand-edit them there. Documented here so a fresh checkout knows they're
# needed. Local engine default if unset: ws://localhost:5565.
ROCKETRIDE_URI=
ROCKETRIDE_APIKEY=
ROCKETRIDE_LOCAL_URI=ws://localhost:5565
# Only needed for extract_skills.pipe's LLM node (R4); extractSkills() in
# src/lib/rocketride/extractSkills.ts works with no key as the fallback.
ROCKETRIDE_GEMINI_KEY=

# Shared app configuration
VITE_API_BASE_URL=http://localhost:3001
