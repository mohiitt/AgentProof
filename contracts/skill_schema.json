{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentproof.dev/contracts/skill_schema.json",
  "title": "AgentProof Skill",
  "description": "A first-class skill used to decompose jobs and scope trust evidence.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "skill_id", "name", "description", "category", "input_type",
    "output_type", "risk_level", "difficulty", "dependencies",
    "typical_failure_modes", "evaluation_criteria", "source"
  ],
  "properties": {
    "skill_id": { "type": "string", "pattern": "^[a-z0-9_]+$" },
    "name": { "type": "string", "minLength": 1 },
    "description": { "type": "string", "minLength": 1 },
    "category": { "type": "string", "minLength": 1 },
    "input_type": { "type": "string", "minLength": 1 },
    "output_type": { "type": "string", "minLength": 1 },
    "risk_level": { "enum": ["low", "medium", "high", "critical"] },
    "difficulty": { "enum": ["beginner", "intermediate", "advanced", "expert"] },
    "dependencies": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
    "typical_failure_modes": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
    "evaluation_criteria": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
    "source": { "type": "string", "minLength": 1 }
  }
}
