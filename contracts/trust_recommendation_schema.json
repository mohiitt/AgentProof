{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentproof.dev/contracts/trust_recommendation_schema.json",
  "title": "AgentProof Trust Recommendation",
  "description": "The trust layer response displayed by the AgentProof frontend.",
  "$defs": {
    "agentRecommendation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["agent_id", "matched_skills", "reason", "confidence", "evidence_ids"],
      "properties": {
        "agent_id": { "type": "string", "minLength": 1 },
        "matched_skills": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
        "reason": { "type": "string", "minLength": 1 },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "evidence_ids": { "type": "array", "items": { "type": "string" }, "uniqueItems": true }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["evidence_id", "summary", "source", "observed_at"],
      "properties": {
        "evidence_id": { "type": "string", "minLength": 1 },
        "summary": { "type": "string", "minLength": 1 },
        "source": { "type": "string", "minLength": 1 },
        "observed_at": { "type": "string", "format": "date-time" }
      }
    }
  },
  "type": "object",
  "additionalProperties": false,
  "required": [
    "request_id", "buyer_id", "task_summary", "required_skills",
    "recommended_agents", "warn_agents", "avoid_agents", "best_agent_or_team",
    "reasoning_summary", "evidence", "risk_level", "confidence"
  ],
  "properties": {
    "request_id": { "type": "string", "minLength": 1 },
    "buyer_id": { "type": "string", "minLength": 1 },
    "task_summary": { "type": "string", "minLength": 1 },
    "required_skills": { "type": "array", "items": { "type": "string" }, "minItems": 1, "uniqueItems": true },
    "recommended_agents": { "type": "array", "items": { "$ref": "#/$defs/agentRecommendation" } },
    "warn_agents": { "type": "array", "items": { "$ref": "#/$defs/agentRecommendation" } },
    "avoid_agents": { "type": "array", "items": { "$ref": "#/$defs/agentRecommendation" } },
    "best_agent_or_team": { "type": "array", "items": { "type": "string" }, "minItems": 1, "uniqueItems": true },
    "reasoning_summary": { "type": "string", "minLength": 1 },
    "evidence": { "type": "array", "items": { "$ref": "#/$defs/evidence" } },
    "risk_level": { "enum": ["low", "medium", "high", "critical"] },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
  }
}
