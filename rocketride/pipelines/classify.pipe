{
  "components": [
    {
      "id": "in",
      "provider": "webhook",
      "name": "raw_event_in",
      "description": "Receives a RawMarketplaceEvent JSON payload (see src/types/rocketride.ts)."
    },
    {
      "id": "anonymize",
      "provider": "anonymize",
      "name": "pii_scrub",
      "description": "R5: strips emails, phone numbers, and account IDs from free-text fields before they become trust evidence. Provider id is a best-effort guess from the docs Nodes list (Text > Anonymize) -- confirm against the live node catalog before running.",
      "input": [{ "lane": "text", "from": "in" }]
    },
    {
      "id": "classify",
      "provider": "http_request",
      "name": "classify_via_map_event",
      "description": "R3: delegates to the RocketRide server adapter's /classify endpoint, which runs src/lib/rocketride/mapEvent.ts. Classification logic (event_type -> edge_type/outcome) is deterministic and lives in one place (mapEvent.ts, unit-tested) rather than being duplicated as pipeline JSON. Wire the real URL once R1's client.ts exposes the endpoint.",
      "config": {
        "method": "POST",
        "url": "${ROCKETRIDE_CLASSIFY_ENDPOINT}"
      },
      "input": [{ "lane": "text", "from": "anonymize" }]
    },
    {
      "id": "out",
      "provider": "response",
      "name": "trust_event_out",
      "description": "Emits a TrustEvent[] matching contracts/trust_event_schema.json.",
      "input": [{ "lane": "text", "from": "classify" }]
    }
  ]
}
