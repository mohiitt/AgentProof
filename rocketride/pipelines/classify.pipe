        },
        "nodeType": "default",
        "formDataValid": true
      },
      "input": [
        {
          "lane": "tags",
          "from": "webhook_1"
        }
      ]
    },
    {
      "id": "anonymize_text_1",
      "provider": "anonymize_text",
      "name": "pii_scrub",
      "description": "R5: strips PII from the raw event text before it becomes trust evidence. Real engine PII detection supersedes the regex fallback in src/lib/rocketride/anonymize.ts, which is used offline instead.",
      "config": {
        "profile": "glinerMultiPII",
        "glinerMultiPII": {
          "anonymizeChar": "█"
        }
      },
      "ui": {
        "position": {
          "x": 0,
          "y": 0
        },
        "nodeType": "default",
        "formDataValid": false
      },
      "input": [
        {
          "lane": "text",
          "from": "parse_1"
        }
      ]
    },
    {
      "id": "response_text_1",
      "provider": "response_text",
      "name": "anonymized_event_out",
      "description": "Returns the anonymized event text. src/server/rocketride/client.ts JSON.parses this and runs mapEvent() (src/lib/rocketride/mapEvent.ts) to derive edge_type/outcome deterministically -- that table is not duplicated here.",
      "config": {},
      "ui": {
        "position": {
          "x": 0,
          "y": 0
        },
        "nodeType": "default",
        "formDataValid": false
      },
      "input": [
        {
          "lane": "text",
          "from": "anonymize_text_1"
        }
      ]
    }
  ],
