{
  "components": [
    {
      "id": "chat_1",
      "provider": "chat",
      "name": "job_brief_in",
      "description": "Receives a free-text job brief, e.g. 'Extract structured data from 500 PDFs into a clean CSV.' Used with client.chat(), not client.send() -- see ROCKETRIDE_COMMON_MISTAKES.md on matching source type to client method.",
      "config": {
        "hideForm": true,
        "mode": "Source",
        "parameters": {},
        "type": "chat"
      },
      "ui": {
        "position": {
          "x": 0,
          "y": 0
        },
        "nodeType": "default",
        "formDataValid": true
      }
    },
    {
      "id": "prompt_1",
      "provider": "prompt",
      "name": "skill_extraction_instructions",
      "config": {
        "instructions": [
          "Given a job brief, return a JSON array of skill_id strings drawn only from the AgentProof skill taxonomy (see contracts/skill_schema.json). Do not invent ids not in the taxonomy."
        ],
        "parameters": {}
      },
      "ui": {
        "position": {
          "x": 0,
          "y": 0
        },
        "nodeType": "default",
        "formDataValid": true
      },
      "input": [
        {
          "lane": "questions",
          "from": "chat_1"
        }
      ]
    },
    {
      "id": "llm_gemini_1",
      "provider": "llm_gemini",
      "name": "skill_extraction_llm",
      "description": "R4 primary path. Runs only if ROCKETRIDE_GEMINI_KEY is set; otherwise callers should use extractSkills() (src/lib/rocketride/extractSkills.ts), the deterministic fallback, instead of this pipeline.",
      "config": {
        "profile": "gemini-2_5-flash",
        "5-flash": {
          "apikey": "${ROCKETRIDE_GEMINI_KEY}"
        }
      },
      "ui": {
        "position": {
          "x": 0,
          "y": 0
        },
        "nodeType": "default",
        "formDataValid": false
      },
      "input": [
        {
          "lane": "questions",
          "from": "prompt_1"
        }
      ]
    },
    {
      "id": "response_answers_1",
      "provider": "response_answers",
      "name": "skill_ids_out",
      "config": {},
      "ui": {
        "position": {
          "x": 0,
          "y": 0
        },
        "nodeType": "default",
        "formDataValid": false
      },
      "input": [
        {
          "lane": "answers",
          "from": "llm_gemini_1"
        }
      ]
    }
  ],
